    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20" BackgroundColor="Aquamarine">
            <Label Text="Enter a Phoneword" FontSize="20"></Label>
            <Entry x:Name="PhoneNumberText" Text="1-555-NETMAUI"></Entry>
            <Button x:Name="TranslateButton" Text="翻译" Clicked="OnTranslate"></Button>
            <Button x:Name="CallButton" Text="拨打" Clicked="OnCall"></Button>
            <controls:RecordButton Source="robot.png" WidthRequest="100" HeightRequest="100" HorizontalOptions="Center"></controls:RecordButton>
            <controls:RecordButton2 Source="i.png" WidthRequest="100" HeightRequest="100" HorizontalOptions="Center"></controls:RecordButton2>
            <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                <controls:RecordButton3 ImageSource="robot.png" CenterHoleRatio="0.31" Size="100" RotationDuration="4000"></controls:RecordButton3>
                <controls:RecordButton4 Grid.Column="1" ImageSource="robot.png" Size="100" CenterHoleColor="White" CenterHoleRatio="0.25"></controls:RecordButton4>
                <Button Text="旋转一下" Grid.Row="1" Clicked="Button_Clicked"></Button>
                <Image x:Name="Pic" Source="dotnet_bot.png" Grid.Row="1" Grid.Column="1"></Image>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>

    
    
