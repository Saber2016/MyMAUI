<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels ="clr-namespace:CanvasUsage.ViewModels"
             x:Class="CanvasUsage.MainPage">

    <ContentPage.BindingContext>
        <viewmodels:MainPageViewModel></viewmodels:MainPageViewModel>
    </ContentPage.BindingContext>

    <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="5" Padding="5">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFB3E5FC" Offset="0.0" />
                <GradientStop Color="#FF81D4FA" Offset="0.5" />
                <GradientStop Color="#FF4FC3F7" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>
        <Border Stroke="AliceBlue" StrokeShape="RoundRectangle 10" Padding="5">
            <VerticalStackLayout Spacing="10" BackgroundColor="AliceBlue">
                <GraphicsView x:Name="DrawBox" HeightRequest="200" WidthRequest="200" Drawable="{Binding MyDraw}"></GraphicsView>
                <BoxView HeightRequest="1"></BoxView>
                <Picker Margin="5" Title="选择绘制图形" SelectedItem="{Binding SelectedFigure}" ItemsSource="{x:Static viewmodels:MainPageViewModel.Figures}" TextColor="Black" ></Picker>
            </VerticalStackLayout>
        </Border>
        <Border Grid.Column="1" Stroke="AliceBlue" StrokeShape="RoundRectangle 10" Padding="5">
            <VerticalStackLayout Spacing="10" Background="AliceBlue">
                <GraphicsView x:Name="TextureDrawBox" HeightRequest="200" WidthRequest="200" Drawable="{Binding MyPaint}"></GraphicsView>
                <BoxView HeightRequest="1"></BoxView>
                <Picker Margin="5" Title="选择绘制纹理" SelectedItem="{Binding SelectedPaint}" ItemsSource="{x:Static viewmodels:MainPageViewModel.Paints}"></Picker>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
